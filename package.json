{
  "name": "bentley-cfg",
  "displayName": "Bentley Workspace Configuration (CFG)",
  "description": "Syntax highlighting, snippets, and IntelliSense for Bentley MicroStation / OpenRoads Designer workspace configuration files (.cfg, .ucf, .pcf)",
  "version": "1.0.0",
  "publisher": "bentley-cfg-tools",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "bentley",
    "microstation",
    "openroads",
    "workspace",
    "cfg",
    "configuration"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/bentley-cfg-vscode"
  },
  "activationEvents": [
    "onLanguage:bentley-cfg"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "bentley-cfg",
        "aliases": [
          "Bentley CFG",
          "MicroStation Configuration",
          "OpenRoads Configuration"
        ],
        "extensions": [
          ".cfg",
          ".ucf",
          ".pcf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bentley-cfg",
        "scopeName": "source.bentley-cfg",
        "path": "./syntaxes/bentley-cfg.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "bentley-cfg",
        "path": "./snippets/bentley-cfg.json"
      }
    ],
    "commands": [
      {
        "command": "bentley-cfg.validateFile",
        "title": "Bentley CFG: Validate Current File",
        "icon": "$(check)"
      },
      {
        "command": "bentley-cfg.insertVariable",
        "title": "Bentley CFG: Insert Variable Reference"
      },
      {
        "command": "bentley-cfg.loadLocalWorkspace",
        "title": "Bentley CFG: Load Local Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "bentley-cfg.loadCurrentFile",
        "title": "Bentley CFG: Resolve Current File",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "bentley-cfg.loadProjectWiseWorkspace",
        "title": "Bentley CFG: Load ProjectWise Managed Workspace",
        "icon": "$(cloud-download)"
      },
      {
        "command": "bentley-cfg.managePwConnections",
        "title": "Bentley CFG: Manage ProjectWise Connections"
      },
      {
        "command": "bentley-cfg.compareWorkspaces",
        "title": "Bentley CFG: Compare Loaded Workspaces",
        "icon": "$(diff)"
      },
      {
        "command": "bentley-cfg.compareFolders",
        "title": "Bentley CFG: Compare Two Workspace Folders",
        "icon": "$(diff-multiple)"
      },
      {
        "command": "bentley-cfg.importCsbManual",
        "title": "Bentley CFG: Import CSB Content Manually",
        "icon": "$(edit)"
      },
      {
        "command": "bentley-cfg.viewMasterTmp",
        "title": "Bentley CFG: View Generated Master Config",
        "icon": "$(file-code)"
      },
      {
        "command": "bentley-cfg.deployWorkspaceToPw",
        "title": "Bentley CFG: Deploy Workspace to ProjectWise",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "bentley-cfg.exportDeploymentPackage",
        "title": "Bentley CFG: Export Deployment Package",
        "icon": "$(package)"
      },
      {
        "command": "bentley-cfg.checkDmwfVersion",
        "title": "Bentley CFG: Check for DMWF Updates"
      }
    ],
    "configuration": {
      "title": "Bentley Workspace Configuration",
      "properties": {
        "bentley-cfg.dmwfDownloadUrl": {
          "type": "string",
          "default": "https://communities.bentley.com/products/projectwise/b/projectwise_blog",
          "description": "URL opened when checking for a newer DMWF (Digital Managed Workspace Framework) package. Defaults to the Bentley Communities ProjectWise blog where DMWF releases are announced. Override with a direct zip URL once your Bentley account locates the latest package."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "bentley-cfg.validateFile",
          "when": "resourceLangId == bentley-cfg",
          "group": "bentley-cfg@1"
        },
        {
          "command": "bentley-cfg.loadCurrentFile",
          "when": "resourceLangId == bentley-cfg",
          "group": "bentley-cfg@2"
        }
      ],
      "editor/title": [
        {
          "command": "bentley-cfg.loadCurrentFile",
          "when": "resourceLangId == bentley-cfg",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "bentley-cfg.validateFile",
          "when": "resourceLangId == bentley-cfg"
        },
        {
          "command": "bentley-cfg.loadCurrentFile",
          "when": "resourceLangId == bentley-cfg"
        },
        {
          "command": "bentley-cfg.loadLocalWorkspace"
        },
        {
          "command": "bentley-cfg.loadProjectWiseWorkspace"
        },
        {
          "command": "bentley-cfg.managePwConnections"
        },
        {
          "command": "bentley-cfg.compareWorkspaces"
        },
        {
          "command": "bentley-cfg.compareFolders"
        },
        {
          "command": "bentley-cfg.importCsbManual"
        },
        {
          "command": "bentley-cfg.viewMasterTmp"
        },
        {
          "command": "bentley-cfg.deployWorkspaceToPw"
        },
        {
          "command": "bentley-cfg.exportDeploymentPackage"
        },
        {
          "command": "bentley-cfg.checkDmwfVersion"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.19.0"
  }
}